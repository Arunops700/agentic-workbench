# Copy to `.env`. All optional — runs offline with the heuristic policy if unset.

# Decision policy: "anthropic" (real Claude tool-use) or "heuristic" (offline rules)
POLICY=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
MAX_TOKENS=1024

# Safety: cap the agent loop so it can never run away
MAX_STEPS=8
